# ═══════════════════════════════════════════════════════════════
# Temple Stuart — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# DATABASE (required)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://user:password@host:5432/temple_stuart?sslmode=require"

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION (required)
# ═══════════════════════════════════════════════════════════════
JWT_SECRET="your-jwt-secret-here"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ═══════════════════════════════════════════════════════════════
# PLAID (Banking Integration) — Required
# ═══════════════════════════════════════════════════════════════
PLAID_CLIENT_ID="your-client-id"
PLAID_SECRET="your-secret"
# Note: App forces production environment for real data

# ═══════════════════════════════════════════════════════════════
# ANTHROPIC (AI Market Brief + Strategy Analysis)
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY="sk-ant-..."

# ═══════════════════════════════════════════════════════════════
# FINNHUB (News + Analyst Ratings) — Free tier, 60 calls/min
# ═══════════════════════════════════════════════════════════════
FINNHUB_API_KEY="your-finnhub-key"

# ═══════════════════════════════════════════════════════════════
# TASTYTRADE (Options Data — Quotes, Chains, Greeks)
# ═══════════════════════════════════════════════════════════════
TASTYTRADE_USERNAME="your-username"
TASTYTRADE_PASSWORD="your-password"

# ═══════════════════════════════════════════════════════════════
# OPENAI — Optional (meal planning, spending insights)
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY="sk-..."

# ═══════════════════════════════════════════════════════════════
# XAI GROK — Optional (trip AI analysis)
# ═══════════════════════════════════════════════════════════════
XAI_API_KEY="xai-..."

# ═══════════════════════════════════════════════════════════════
# DUFFEL (Flight Booking) — Optional
# ═══════════════════════════════════════════════════════════════
DUFFEL_API_TOKEN="duffel_live_..."

# ═══════════════════════════════════════════════════════════════
# GOOGLE PLACES — Optional (trip recommendations)
# ═══════════════════════════════════════════════════════════════
GOOGLE_PLACES_API_KEY="AIza..."
# Hard monthly bill-protection cap on Google Places/Maps API calls (default 5000).
# When crossed the travel scan fails loud (429) instead of bleeding spend.
GOOGLE_PLACES_MONTHLY_CAP="5000"
# Days a city/category stays served from places_cache with zero Google calls (default 7).
PLACES_CACHE_TTL_DAYS="7"

# ═══════════════════════════════════════════════════════════════
# LITEAPI — Hotels (bookable inventory for Accommodation category)
# ═══════════════════════════════════════════════════════════════
# Sandbox key (default) — get from LiteAPI dashboard "Sandbox" tab.
LITEAPI_SANDBOX_KEY="sand_..."
# Production key — get from LiteAPI dashboard "Production" tab once approved.
LITEAPI_PRODUCTION_KEY=""
# Flip to "production" once the prod key is set and you're ready for real
# bookings. Defaults to sandbox.
LITEAPI_MODE="sandbox"

# ═══════════════════════════════════════════════════════════════
# STRIPE — Optional (subscriptions)
# ═══════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_PRO_PLUS_PRICE_ID="price_..."

# ENTITLEMENT-WRITER — per-key purchase prices (Alex creates each product in
# Stripe and fills the price ID; a key with NO env var set is simply NOT
# purchasable — checkout 400s, nothing is ever granted as a fallback).
# Env name derivation: entitlementPriceEnvName() in src/lib/stripe.ts.
# Google categories (the 9 GOOGLE_CATEGORY_KEYS):
STRIPE_CAT_BRUNCH_COFFEE_PRICE_ID=""
STRIPE_CAT_DINNER_PRICE_ID=""
STRIPE_CAT_NIGHTLIFE_PRICE_ID=""
STRIPE_CAT_COWORKING_PRICE_ID=""
STRIPE_CAT_GYMS_PRICE_ID=""
STRIPE_CAT_SPORTS_PRICE_ID=""
STRIPE_CAT_GROCERIES_PRICE_ID=""
STRIPE_CAT_SHOPPING_PRICE_ID=""
STRIPE_CAT_FESTIVALS_PRICE_ID=""
# Module tabs (TAB_ENTITLEMENT_KEYS):
STRIPE_TAB_TRAVEL_PRICE_ID=""
STRIPE_TAB_TRADE_PRICE_ID=""
STRIPE_TAB_BOOKS_PRICE_ID=""
STRIPE_TAB_TAX_PRICE_ID=""
STRIPE_TAB_OPERATIONS_PRICE_ID=""
STRIPE_TAB_COMPLIANCE_PRICE_ID=""
# All-tabs bundle (bundle:all — one purchase unlocks every tab at read time):
STRIPE_BUNDLE_ALL_PRICE_ID=""

# ═══════════════════════════════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_PASSWORD="your-admin-password"
CRON_SECRET="your-cron-secret"
OWNER_EMAIL="your-email@example.com"
NEXT_PUBLIC_OWNER_EMAIL="your-email@example.com"

# ═══════════════════════════════════════════════════════════════════════════
# INNGEST (optional in dev; required in production)
# ═══════════════════════════════════════════════════════════════════════════
# Inngest powers durable workflow execution for ingestion workers and the
# multi-model ensemble. In local development, the Inngest Dev Server runs
# at http://localhost:8288 and these keys are NOT required. In production
# (Vercel), both keys must be set from the Inngest Cloud project settings.
INNGEST_EVENT_KEY="signkey-prod-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
INNGEST_SIGNING_KEY="signkey-prod-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ═══════════════════════════════════════════════════════════════════════════
# PHASE 3 — Claude Code audit Routine (the auto CC-audit)
# ═══════════════════════════════════════════════════════════════════════════
# Server-only. The app fires a Claude Code Routine to run the read-only codebase
# audit; the Routine POSTs its findings back (PHASE3-3). FIRE_URL is the Routines
# /fire endpoint; TOKEN is the bearer used to authorize the fire (server-side
# only, never client-exposed). Gated by requireRoutineBudget (a separate daily
# meter). Absent → fireAuditRoutine fails loud (no fire).
ROUTINE_AUDIT_FIRE_URL=""
ROUTINE_AUDIT_TOKEN=""

# ═══════════════════════════════════════════════════════════════════════════
# PHASE 3 — Claude Code audit Routine ingest callback (server-only)
# ═══════════════════════════════════════════════════════════════════════════
# AUDIT_INGEST_SECRET is the shared-secret bearer the Claude Code audit Routine
# uses to POST its findings back to /api/operations/projects/[id]/audit-ingest.
# It is the ENTIRE auth boundary for that inbound write (the Routine has no user
# cookie) — validated first, before any DB work. Set the SAME value in Vercel AND
# as the Routine's callback Authorization. Absent → the callback returns 500.
AUDIT_INGEST_SECRET=""

# ═══════════════════════════════════════════════════════════════════════════
# EXEC — Claude Code "Execute Task" Routine (the execution pipe, build + PR)
# ═══════════════════════════════════════════════════════════════════════════
# Server-only. The app fires a separate Execute-Task Routine to BUILD an accepted
# task on a claude/ branch and open a PR; the Routine POSTs the PR url + status back
# (exec-ingest). FIRE_URL is the Routines /fire endpoint; TOKEN authorizes the fire.
# EXEC_INGEST_SECRET is the shared-secret bearer for the inbound exec-ingest callback
# (the Routine has no user cookie — it's the entire auth boundary, validated first).
# Gated by requireExecBudget (a separate daily meter). Absent → fail loud (no fire).
EXEC_ROUTINE_FIRE_URL=""
EXEC_ROUTINE_TOKEN=""
EXEC_INGEST_SECRET=""

# Voyage AI embeddings (PR-K)
# Required for the regulatory corpus embedding worker.
# Sign up at https://www.voyageai.com to obtain a key.
# Pricing: voyage-3.5 at $0.06/M input tokens.
# Set Voyage organization-level budget cap separately for vendor-side
# emergency stop (current: $50/month).
VOYAGE_API_KEY=
